<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Distributor OCR Processor</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 600px; margin: 40px auto; padding: 20px; }
        .upload-box { border: 2px dashed #ccc; padding: 20px; text-align: center; border-radius: 8px; margin-bottom: 20px;}
        button { padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; }
        button:disabled { background-color: #ccc; }
        pre { background: #f4f4f4; padding: 15px; overflow-x: auto; border-radius: 4px; }
        .error { color: red; font-weight: bold; }
    </style>
</head>
<body>

    <h2>Upload Distributor Receipts</h2>
    
    <div id="auth-section" style="margin-bottom: 20px; padding: 15px; background-color: #f8f9fa; border-radius: 8px; border: 1px solid #ddd;">
        <strong>Step 1:</strong> 
        <a href="/api/auth/login" style="padding: 8px 15px; background-color: #4285F4; color: white; text-decoration: none; border-radius: 4px; display: inline-block; margin-left: 10px;">Authorize Google Sheets</a>
        <span style="margin-left: 10px; font-size: 0.9em; color: #555;">(Required before exporting)</span>
    </div>

    <div id="workbook-section" style="display: none; margin-bottom: 20px; padding: 15px; background-color: #e9ecef; border-radius: 8px; border: 1px solid #ccc;">
        <strong>Step 2:</strong>
        <label for="workbook-select" style="font-weight: bold; margin-left: 10px;">Select Target Workbook:</label>
        <select id="workbook-select" style="margin-left: 10px; padding: 6px; min-width: 250px; border-radius: 4px;">
            <option value="">Loading workbooks...</option>
        </select>
    </div>

    <p>Select up to 3 receipt images (Summary, Gross Profit, Payments).</p>

    <form id="ocr-form">
        <div class="upload-box">
            <input type="file" id="receipts" name="receipts" accept="image/*" multiple required>
        </div>
        <button type="submit" id="submit-btn">Process Receipts</button>
    </form>

    <h3>Extraction Results:</h3>
    <div id="status-message"></div>
    
    <textarea id="json-output" style="width: 100%; height: 300px; font-family: monospace; padding: 10px;" placeholder="Awaiting upload..."></textarea>
    
    <button id="export-btn" style="display: none; margin-top: 15px; background-color: #28a745;">Confirm & Send to Sheets</button>

    <script src="app.js"></script>
</body>
</html>